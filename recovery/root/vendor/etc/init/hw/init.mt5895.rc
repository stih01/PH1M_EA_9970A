import /vendor/etc/init/hw/init.mkn.rc
import /vendor/etc/init/hw/init.mtk_common.rc
import /vendor/etc/init/hw/init.${ro.hardware}.usb.rc
import /vendor/etc/init/hw/init.boottime_trace.rc
import /vendor/etc/init/hw/init.mtkwifi.rc
import /vendor/etc/init/hw/init.abupdate.rc

on early-init
    loglevel 7
    # insmod /vendor/lib/modules/mtk-hcd.ko
    insmod /vendor/lib/modules/usb-storage.ko
    mount debugfs /sys/kernel/debug /sys/kernel/debug mode=755
    mount tracefs /sys/kernel/tracing /sys/kernel/tracing mode=755

on init
    loglevel 7
    # tmp solution to disable dmesg for CTS (android.security) before SELinux is ready
    write /proc/sys/kernel/dmesg_restrict 1
	# boottime stune
    write /dev/stune/schedtune.prefer_idle 1
    write /dev/stune/schedtune.boost 100
    #write /proc/sys/kernel/printk 7
    write /proc/sys/kernel/sysrq 1

on property:sys.boot_completed=1
    # reset stune
    write /dev/stune/schedtune.prefer_idle 0
    write /dev/stune/schedtune.boost 0

on early-fs
    wait /dev/block/platform/soc/1006d000.MSDC0
    symlink /dev/block/platform/soc/1006d000.MSDC0 /dev/block/bootdevice
    # mount partitions
    mount_all /vendor/etc/fstab.mt5895 --early
    mount ext4 /dev/block/bootdevice/by-name/perm /perm rw context=u:object_r:perm_fs:s0

on early-fs && property:ro.boot.format_blkdev=*
    exec_start mt_format_blkdev

on fs
    restorecon_recursive /vendor
    restorecon_recursive /vendor/config/pq
    # mount Upgrade
    #mkdir /upgrade

    restorecon_recursive /data/vendor/user_setting
on post-fs
    # start console service earlier here
    restorecon_recursive /perm
    start console

on late-fs
    mount_all /vendor/etc/fstab.mt5895 --late

on post-fs-data
    # boot time fs tune
    write /sys/block/mmcblk0/queue/iostats 0
    write /sys/block/mmcblk0/queue/scheduler cfq
    write /sys/block/mmcblk0/queue/iosched/slice_idle 0
    write /sys/block/mmcblk0/queue/read_ahead_kb 2048
    write /sys/block/mmcblk0/queue/nr_requests 256
    write /sys/block/dm-0/queue/read_ahead_kb 2048
    write /sys/block/dm-1/queue/read_ahead_kb 2048
    write /sys/block/dm-2/queue/read_ahead_kb 2048
    
    mkdir /data/vendor/mediadrm
    #XMIC Start Porting to P 
    #mkdir /data/debugdump 0777 system root
    #mkdir /data/tombstones 0776 system system
    #mkdir /data/javacrash 0776 system system
    mkdir /data/vendor/debugdump 0777 root root
    mkdir /data/vendor/tombstones 0776 root root
    mkdir /data/vendor/javacrash 0776 root system
    mkdir /data/vendor/anr 0776 root root

    #for demome clips
    mkdir /data/vendor/TPV 0777 system system
    mkdir /data/vendor/TPV/demome 0777 system system

    #for oad
    mkdir /data/vendor/oad 0777 system system
    restorecon /data/vendor/oad

    #add for fix ginga selinux issue
	mount tmpfs tmpfs /mnt/vendor/3rd/ginga/application size=8M mode=1771
	mount none /mnt/vendor/3rd/ginga/lib /mnt/vendor/linux_rootfs/basic/ginga/lib bind
    
    #XMIC End Porting to P
    mkdir /data/vendor/mediadrm 0770 mediadrm mediadrm
    restorecon /data/vendor/mediadrm
 
    mkdir /data/vendor/tmp 0771 root system
    mount tmpfs tmpfs /data/vendor/tmp size=10M nr_inodes=1k mode=1771 
    chown root system /data/vendor/tmp
    
    mkdir /data/vendor/errlog 0777
    restorecon /data/vendor/errlog
    
    mkdir /data/vendor/etc
    chmod 777 /data/vendor/etc
    write /data/vendor/etc/resolv.conf "nameserver 8.8.8.8"
    chmod 777 /data/vendor/etc/resolv.conf
    mkdir /data/vendor/fifo
    chmod 777 /data/vendor/fifo

    mkdir /mnt/vendor/tmp
    mount tmpfs tmpfs /mnt/vendor/tmp size=100M nr_inodes=1k mode=1771
    
	#tpv cp-media-xml
	start cp-media-xml
	start cp-wifi-dat
	mkdir /data/vendor/ 0775 system system
    mkdir /data/vendor/3rd_rw
    mkdir /data/vendor/user_setting
	#mkdir /data/upgrade/ 0777 system system 
	#mkdir /data/upgrade/oad/ 0777 system system 
    mount_all /vendor/etc/fstab.late.mt5895
    restorecon_recursive /data/vendor/user_setting
    restorecon_recursive /data/vendor/3rd_rw
	#restorecon_recursive /data/upgrade
    #restorecon_recursive /tpv_misc
    
	mkdir /data/vendor/tvupgrades 0777 system system
	restorecon /data/vendor/tvupgrades
	
    symlink /system/etc/localtime /data/vendor/3rd_rw/localtime

    start zram-svc
    wait /mnt/vendor/tmp/zram_start
    insmod /vendor/lib/modules/dtv_dolby_vision.ko
    insmod /vendor/lib/modules/mtk_core.ko
    insmod /vendor/lib/modules/usbcam.ko
    insmod /vendor/lib/modules/dtv_driver.ko osd2_src_width=1920 osd2_src_height=1080
    insmod /vendor/lib/modules/devnode.ko
    insmod /vendor/lib/modules/mali_kbase.ko
    insmod /vendor/lib/modules/fusion.ko
    insmod /vendor/lib/modules/snd-mtk.ko
    insmod /vendor/lib/modules/videodev.ko
    insmod /vendor/lib/modules/v4l2-common.ko
    insmod /vendor/lib/modules/videobuf2-common.ko
    insmod /vendor/lib/modules/videobuf2-memops.ko
    insmod /vendor/lib/modules/videobuf2-vmalloc.ko
    insmod /mnt/vendor/linux_rootfs/basic/fusion.ko
    insmod /vendor/lib/modules/tpvinput.ko
	insmod /vendor/lib/modules/texfat.ko

    # video4linux kernel modules added in kernel-4.9
    insmod /vendor/lib/modules/v4l2-dv-timings.ko
    insmod /vendor/lib/modules/videobuf2-v4l2.ko

    insmod /vendor/lib/modules/uvcvideo.ko
    insmod /vendor/lib/modules/ntfs.ko
    insmod /system/lib/modules/musb_hdrc_u3.ko
    insmod /vendor/lib/modules/star_mac.ko
    insmod /vendor/lib/modules/brd.ko

    insmod /vendor/lib/modules/snd-hwdep.ko
    insmod /vendor/lib/modules/snd-usbmidi-lib.ko
    insmod /vendor/lib/modules/snd-usb-audio.ko

    chown root shell /unmount.sh
    chmod 0550 /unmount.sh

    # bluetooth
    mkdir /data/vendor/@btmtk 0770 bluetooth net_bt

    # Logcat usage
    mkdir /data/vendor/logcat
    restorecon /data/vendor/logcat

    # MTK tmp
    mkdir /mnt/vendor/tmp/mtk 0770 root system
    mkdir /mnt/vendor/tmp/image 0770 root system
    restorecon_recursive /mnt/vendor/tmp/mtk
    restorecon_recursive /mnt/vendor/tmp/image

    # Google Storage
    mkdir /data/vendor/3rd_rw/google_storage 0700 system system
    restorecon /data/vendor/3rd_rw/google_strage

    # Resource Manager
    restorecon /vendor/bin/MtkRmServer
    

    chmod 0777 /data/vendor/user_setting/rw
	chmod 0777 /data/vendor/user_setting/ro
    mkdir /data/vendor/user_setting/rw/databases 0777
    mkdir /data/vendor/user_setting/rw/upgrade 0777
    mkdir /data/vendor/user_setting/temp 0777
    mkdir /data/vendor/user_setting/rw/userlogos 0777
    
	#chmod 0777 /data/upgrade 
	#chown system system /data/upgrade
	#chmod 0777 /data/upgrade/oad
	#chown system system /data/upgrade/oad
    #chmod 0777 /tpv_misc/
	
    on early-boot
    write /proc/boottime "before /dev/mali0"
    wait /dev/mali0
    write /proc/boottime "after /dev/mali0"

    # blackbox folder
    mkdir /data/vendor/blackbox/ 0775 system system
    restorecon_recursive /data/vendor/blackbox
    
    # perm folders
    mkdir /perm/PSTVK003 0775 root system
    mkdir /perm/PSTVK015 0775 root system
    mkdir /perm/widevine 0775 root system
    restorecon_recursive /perm
    mount ext4 /dev/block/bootdevice/by-name/perm /perm ro remount
	
	#exec - root -- /system/bin/cppreopts.sh
	#restorecon_recursive /data/dalvik-cache/arm
	

on boot
    #mount debugfs /sys/kernel/debug /sys/kernel/debug
    mkdir /data/vendor/wifi 0777 root root
    mkdir /data/vendor/wifi/wpa 0770 wifi wifi
    mkdir /data/vendor/wifi/wpa/sockets 0770 wifi wifi
    mkdir /data/vendor/misc/dhcp 0770 dhcp dhcp
    chmod 0775 /data/vendor/misc/dhcp
    chmod 0770 /dev/tpvinput
    chown dhcp dhcp /data/vendor/misc/dhcp
    chown system system /sys/module/mtk_mod/parameters/reset_reason
    chown root system /dev/tpvinput
    chown root system /sys/power/wake_lock
    chown root system /sys/power/wake_unlock
    # add by weichuang for bt sink uart @2021.6.4
    chmod 0666 /dev/ttyMT1

    # for memtrack
    chmod 0711 /sys/kernel/debug

    # update foreground cpuset now that processors are up
    write /dev/cpuset/foreground/cpus 0-2
    write /dev/cpuset/foreground/boost/cpus 0-2
    write /dev/cpuset/background/cpus 0
    write /dev/cpuset/system-background/cpus 0-1
    write /dev/cpuset/top-app/cpus 0-3
    write /proc/sys/net/core/rmem_max 262144


# make sure "main" services are running
# !!NOTES: "class_start core" is in init.rc
    class_start main

# start: moved from mtk init.rc
#service fuse_sdcard /vendor/bin/sdcard -u 1023 -g 1023 -w 1023 -d /mnt/media_rw/sdcard /storage/sdcard
#    class late_start
#    disabled
#    seclabel u:r:sdcardd:s0
# end

# mtk_rm service
service mtk_rm /vendor/bin/sh /vendor/bin/mtk_rm.sh
    class main
    group readproc
    oneshot
    seclabel u:r:mt_mtk_rm:s0

# bootanim: start: moved from mtk init.rc
#  service bootanim /system/bin/bootanimation
#  replace original bootanimation binary for early TV playback
#service bootanim /system/bin/dtv_bootanim 1 0
service bootanim /system/bin/bootanimation
    class main
    user graphics
    group graphics
    disabled
    oneshot
# bootanim: end

service insmod /vendor/bin/sh /vendor/etc/script/insmod.sh
    class main
    oneshot
    seclabel u:r:mt_insmod:s0

service tvnativeserver /vendor/bin/tvnativeserver
    class main
    oneshot
    seclabel u:r:tvnativeserver:s0
# dtv_svc service
service dtv-svc /vendor/bin/sh /vendor/bin/dtv_svc.sh
    class main
    console
    group root media_rw system everybody
    oneshot
    seclabel u:r:mt_dtv-svc:s0
    priority -1

#Added to improve BootTime
on property:sys.boot_completed=1
    exec u:r:shell:s0 shell shell log readproc -- /system/bin/sh /system/bin/am startservice -n org.droidtv.playtv/.services.PlayTvStartupService

# zram service
service zram-svc /vendor/bin/sh /vendor/bin/setup_zram.sh
    class main
    oneshot
    seclabel u:r:mt_zram-svc:s0

# wlan dongle detect service
service wlan_dongle_detect /vendor/bin/wlan_dongle_detect
    class core
    console
    oneshot
    seclabel u:r:mt_wlan_dongle_detect:s0

service wpa_supplicant /vendor/bin/hw/wpa_supplicant -g@android:wpa_wlan0 -G1010 -O/data/vendor/wifi/wpa/sockets -Dnl80211 -iwlan0 -c /vendor/etc/wifi/wpa_supplicant.conf -N -Dnl80211 -ip2p0 -c /vendor/etc/wifi/p2p_supplicant.conf -puse_p2p_group_interface=1 -d
    class main
    interface android.hardware.wifi.supplicant@1.0::ISupplicant default
    interface android.hardware.wifi.supplicant@1.1::ISupplicant default
    interface android.hardware.wifi.supplicant@1.2::ISupplicant default
    socket wpa_wlan0 dgram 660 wifi wifi
    disabled
    oneshot

service wpa_supplicantrt /vendor/bin/hw/wpa_supplicantrt -Dnl80211 -iwlan0 -c /data/vendor/misc/wifi/wpa.conf
    class main
    disabled
    oneshot
    seclabel u:r:wpa:s0

service p2p_supplicantrt /vendor/bin/hw/wpa_supplicantrt -Dnl80211 -iwlan0 -c /data/vendor/misc/wifi/p2p.conf -e /data/vendor/misc/wifi/entropy.bin
    class main
    disabled
    oneshot
    seclabel u:r:wpa:s0

service wpa_supplicant6k /vendor/bin/hw/wpa_supplicantat6k -iwlan0 -Dnl80211 -c /data/vendor/misc/wifi/wpa.conf
    class main
    disabled
    oneshot
    #seclabel u:r:wpa:s0

service p2p_supplicant6k /vendor/bin/hw/wpa_supplicantat6k -ip2p0 -Dnl80211 -c /data/vendor/misc/wifi/p2p.conf
    class main
    disabled
    oneshot
    seclabel u:r:wpa:s0

service wifi_set  /vendor/bin/wifi_set.sh
    disabled
    oneshot
    seclabel u:r:mt_wifi_set:s0

service dhcpcd /vendor/bin/dhcpcd -BK
    class main
    disabled
    oneshot

service dhcpcd_eth0 /vendor/bin/dhcpcd -BK
    class main
    disabled
    oneshot

service dhcpcd_wlan0 /vendor/bin/dhcpcd -BK
    class main
    disabled
    oneshot

service dhcpcd_p2p /vendor/bin/dhcpcd -BK
    class main
    disabled
    oneshot
#support ipv6

service dhcp6cDNS_wlan0 /vendor/bin/dhcp6c -c "/etc/wide-dhcpv6/dhcp6cDNS_wlan0.conf" -Df wlan0
    class main
    disabled
    oneshot
    seclabel u:r:mt_dhcpv6:s0
	
service dhcp6c_eth0 /vendor/bin/dhcp6c -c "/etc/wide-dhcpv6/dhcp6c.conf" -Df eth0
    class main
    disabled
    oneshot
    seclabel u:r:mt_dhcpv6:s0

service dhcp6c_wlan0 /vendor/bin/dhcp6c -c "/etc/wide-dhcpv6/dhcp6c_wifi.conf" -Df wlan0
    class main
    disabled
    oneshot
    seclabel u:r:mt_dhcpv6:s0
	
service dhcp6cDNS_eth0 /vendor/bin/dhcp6c -c "/etc/wide-dhcpv6/dhcp6cDNS_eth0.conf" -Df eth0
    class main
    disabled
    oneshot
    seclabel u:r:mt_dhcpv6:s0
	
on property:service.dhcp6c_wlan0.enable=0    
    stop dhcp6c_wlan0    

on property:service.dhcp6c_wlan0.enable=1
    start dhcp6c_wlan0

service dhcp6c_PD /vendor/bin/dhcp6c -c "/etc/wide-dhcpv6/dhcp6cPD.conf" -Df
    disabled
    oneshot
    seclabel u:r:mt_dhcpv6:s0

service wifi_fw_check /vendor/bin/wifi_fw_check
    class main
    disabled
    oneshot
    seclabel u:r:mt_wifi_fw_check:s0

service iwpriv_operation /vendor/bin/iwpriv_wifi_operation
    class main
    disabled
    oneshot
    seclabel u:r:mt_iwpriv_wifi_oper:s0

service wakelock_proxy /vendor/bin/wakelock_proxy
    class main
    oneshot
    seclabel u:r:mt_wakelock_proxy:s0

service storageproxyd /vendor/bin/storageproxyd -d /dev/trusty-ipc-dev0 -p /data/vendor/3rd_rw/google_storage/ -r /dev/mmcblk0rpmb
    class main
    group system mediadrm
    seclabel u:r:storageproxyd:s0

service iprenew_wlan0 /vendor/bin/dhcpcd -n
    class main
    disabled
    oneshot

service iprenew_eth0 /vendor/bin/dhcpcd -n
    class main
    disabled
    oneshot
# bugreport is triggered by the KEY_VOLUMEUP and BTN_MOUSE keycodes
#service bugreport /system/bin/dumpstate -d -v -o /usbdisk/bugreports/bugreportservice bugreport /system/bin/dumpstate -d -p -B -z -o /data/user_de/0/com.android.shell/files/bugreports/bugreport
service bugreport /system/bin/dumpstate -d -p -B -z -o /data/user_de/0/com.android.shell/files/bugreports/bugreport
    class main
    disabled
    oneshot
    keycodes 470

# k2logcat service
service k2logcat /vendor/bin/k2logcat
    class main
    disabled
    oneshot
    seclabel u:r:mt_k2logcat:s0
    priority 19

on property:dhcp.eth0.dns1=*
    write /data/vendor/etc/resolv.conf "nameserver ${dhcp.eth0.dns1}"
    restorecon /data/vendor/etc/resolv.conf

on property:vendor.mtk.net.dns1=*
    start updatedns

# updatedns service
service updatedns /vendor/bin/update_linux_network
    class main
    disabled
    oneshot
    seclabel u:r:mt_updatedns:s0

# updatedhcp service
service updateDhcpServer /vendor/bin/update_dhcp_server
    class main
    disabled
    oneshot
    seclabel u:r:mt_updateDhcpServer:s0

on property:dhcp.server=*
    start updateDhcpServer

# wowl on
service wowl_on /vendor/bin/sh /vendor/bin/wowl_on.sh
    oneshot
    disabled
    seclabel u:r:mt_wowl:s0

#wowl off
service wowl_off /vendor/bin/sh /vendor/bin/wowl_off.sh
    oneshot
    disabled
    seclabel u:r:mt_wowl:s0

# wowcast on
service wowcast_on /vendor/bin/sh /vendor/bin/wowcast_on.sh
    oneshot
    disabled
    seclabel u:r:mt_wowl:s0

#wowcast off
service wowcast_off /vendor/bin/sh /vendor/bin/wowcast_off.sh
    oneshot
    disabled
    seclabel u:r:mt_wowl:s0

# format block device
service mt_format_blkdev /vendor/bin/sh /vendor/bin/mt_format_blkdev.sh
    console
    oneshot
    disabled
    seclabel u:r:vendor_init:s0

# aiaq_audio service //tpv is marked originally
#service aiaq-audio /vendor/bin/aiaq_audio
#    setenv LD_LIBRARY_PATH /system/lib
#    class main
#    user system
#    group system
#    console
#    oneshot
#    seclabel u:r:mt_aiaq_audio-svc:s0	

#XMIC Start Porting to P 
service HomeTesterLogcatVendor /vendor/bin/HomeTesterLogcat
    disabled
    oneshot
    seclabel u:r:tpvdebug:s0
    priority 19

service HomeTesterLogcat /system/bin/HomeTesterLogcat
    disabled
    oneshot
    seclabel u:r:tpvdebug:s0
    priority 19

on property:odm.tpv.debug.USBLoggingStopper=1
    stop HomeTesterLogcat

on property:odm.tpv.debug.USBLoggingStopper=0
    start HomeTesterLogcat

service ddgVendor /vendor/bin/ddg
    class main
    priority 19

service ddg /system/bin/ddg
    class main
    priority 19

service klogcapture /system/bin/klogcapture
    class main
    priority 19

on property:odm.tpv.debug.resetLogd=1
    stop logd
	stop k2logcat

on property:odm.tpv.debug.resetLogd=2
    start logd
	start k2logcat

#logger with service
on property:odm.tpv.sys.droidtv.FWlogger=1
   exec u:r:shell:s0 shell shell log readproc -- /system/bin/sh /system/bin/am startservice org.droidtv.tv.frameworklogger/.FrameworkLogger

#logger with recevier
on property:odm.tpv.sys.droidtv.FWlogger=2
   exec u:r:shell:s0 shell shell log readproc -- /system/bin/sh /system/bin/am broadcast --receiver-permission org.droidtv.permission.TPVISION_BROADCASTS -a org.droidtv.tv.intent.action.DEBUGDUMP_LOGGER

#start UBSbreakinservice and HDDVolumeStateService
on property:sys.user.0.ce_available=true
   exec u:r:shell:s0 shell shell log readproc -- /system/bin/sh /system/bin/am startservice org.droidtv.usbbreakin/.UsbBreakinService
   exec u:r:shell:s0 shell shell log readproc -- /system/bin/sh /system/bin/am startservice org.droidtv.settings/org.droidtv.hddwizard.control.HDDVolumeStateService


#XMIC End Porting to P 
on property:odm.tpv.sys.wowl_on=1
    start wowl_on

on property:odm.tpv.sys.wowl_on=0
    start wowl_off

on property:persist.odm.tpv.sys.WOWCAST=1 
    start wowcast_on

on property:persist.odm.tpv.sys.WOWCAST=0
    start wowcast_off

# This cmd is to set the mlock resouce max value for jpg hw decoder. PageAlign((8096*5403+ 15 * 16383)*2).
on early-init
    setrlimit 8 87977984 87977984

on property:init.svc.bootanim=running
    restorecon /dev/stune/foreground/tasks
    restorecon /dev/stune/top-app/tasks

on property:sys.boot_completed=1
    #end boot time fs tune
    write /sys/block/mmcblk0/queue/rq_affinity 0
    write /sys/block/mmcblk0/queue/read_ahead_kb 128
    write /sys/block/mmcblk0/queue/nr_requests 128
    write /sys/block/dm-0/queue/read_ahead_kb 128
    write /sys/block/dm-1/queue/read_ahead_kb 128
    write /sys/block/dm-2/queue/read_ahead_kb 128
    write /sys/block/mmcblk0/queue/iostats 1
	write /proc/sys/vm/extra_free_kbytes 40960
    start clearCounter

service DrmDumpTest /vendor/bin/blackBox 16
    disabled
    group system mediadrm
    oneshot
    seclabel u:r:blackBox:s0

service keyMasterRun /vendor/bin/blackBox 15
    disabled
    group system mediadrm
    oneshot
    seclabel u:r:blackBox:s0
    
service keyMasterDbg /vendor/bin/blackBox 15 9527 3
    disabled
    group system mediadrm
    oneshot
    seclabel u:r:blackBox:s0
    priority 19

service uartLogger /vendor/bin/blackBox 18
    class main
    group system mediadrm
    oneshot
    seclabel u:r:blackBox:s0
    priority 19

on property:odm.tpv.debug.keyMasterRun=0
    stop keyMasterRun
    stop keyMasterDbg

on property:odm.tpv.debug.keyMasterRun=1
    start keyMasterRun
    
on property:odm.tpv.debug.keyMasterRun=2
    start keyMasterDbg

on property:odm.tpv.debug.keyMasterRun=3
    start DrmDumpTest

#TPV Patrick, 2017.04.05, for reboot counter function (ref: ASTA)
service clearCounter /vendor/bin/clearRebootCounter
    disabled
    oneshot
    seclabel u:r:clearRebootCounter:s0
service offrs_jb_service_offrs /vendor/bin/offrs_jb_service offrs_func
    class main
    user system
    group system
    oneshot
    disabled
    seclabel u:r:offrs_jb_service:s0

service offrs_jb_service_jb /vendor/bin/offrs_jb_service jb_func
    class main
    user system
    group system
    oneshot
    disabled
    seclabel u:r:offrs_jb_service:s0
    
on property:sys.oled.fun=offrs_func
   start offrs_jb_service_offrs
on property:sys.oled.fun=jb_func
   start offrs_jb_service_jb

# tpv cp-wifi-dat service
#service cp-wifi-dat /vendor/bin/sh /vendor/bin/cp-wifi-dat.sh
#    class main
#    oneshot
#    seclabel u:r:mt_cp-media-xml:s0  
	
service rebootservice /vendor/bin/sh /vendor/bin/reboot.sh
    class main
    user root
    disabled
    oneshot
	seclabel u:r:rebootservice:s0

#playfi service
#service playfi_service /system/bin/playfiaudioservice /data/misc/bluedroid/.playfi_ctrl /data/misc/bluedroid/.playfi_data /data/misc/bluedroid/.playfi_appctrl
service playfi_service /vendor/bin/playfiaudioservice /data/misc/bluedroid/.playfi_ctrl /data/misc/bluedroid/.playfi_data /data/misc/bluedroid/.playfi_data_mc /data/misc/bluedroid/.playfi_appctrl
       class main
       user system
       group system
	   capabilities SYS_NICE
       seclabel u:r:playfi_bin:s0


on property:odm.tpv.sys.service.PlayFiAudioServiceEnable=1
    start playfi_service

on property:odm.tpv.sys.service.PlayFiAudioServiceEnable=0
    stop playfi_service

on property:odm.tpv.sys.update=*
       exec - root -- /system/bin/rm_dexopt_sec.sh
       restorecon_recursive /data/dalvik-cache/arm

# For to set ro.oem.key1(DTV01352868)
on property:ro.vendor.mtk.oem.lock=1
       setprop ro.oem.key1 ${ro.vendor.mtk.oem.key}

