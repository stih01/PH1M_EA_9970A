#############  Trigger part ###################

on early-init

on init
    ## Global environment: addition/modification to init.environ.rc.in ##
    export LD_LIBRARY_PATH /vendor/lib:/system/lib64:/system/lib:/product/lib:/product/lib64:/vendor/lib64

    ### valgrind (from init.rc) ###
    export VALGRIND_LIB /system/lib/valgrind
    
    ### Set up MTK linux world partition path ###
    export LINUX_3RD_PATH /mnt/vendor/3rd
    export LINUX_3RD_RW_PATH /data/vendor/3rd_rw
    export LINUX_BASIC_PATH /mnt/vendor/linux_rootfs/basic
    export LINUX_ETC_PATH /mnt/vendor/linux_rootfs/etc
    export LINUX_PERM_PATH /perm
    export LINUX_ROOTFS_PATH /mnt/vendor/linux_rootfs
    export LINUX_TMP_PATH /mnt/vendor/tmp
    export LINUX_PERSIST_PATH /vendor/persist
    export LINUX_RECIPE_PATH /vendor/recipe

    mkdir /mnt/media_rw/sdcard 0700 media_rw media_rw
    mkdir /storage/sdcard 0751 root sdcard_r

    export ANDROID_SYSTEM_EXIST true

on fs
    setprop ro.crypto.fuse_sdcard true

on post-fs
    #basic
    restorecon_recursive /mnt/vendor/linux_rootfs/basic
    # Logcat folder
    restorecon_recursive /data/vendor/logcat
    # smb folder
    restorecon_recursive /data/vendor/misc/smb

    # Support legacy paths
    symlink /sdcard /mnt/sdcard
    symlink /sdcard /storage/sdcard0
    symlink /sdcard /storage/sdcard

on post-fs-data

    mkdir /data/vendor/media 0770 media_rw media_rw
    setprop vold.post_fs_data_done 1

### widevine ###
    # create for widevine
    mkdir /data/vendor/widevine 0777 system system

    # symlink for GTS widevine L1 , L3 platfrom should not be exist
    #symlink /system/lib/libmtal.so /vendor/lib/liboemcrypto.so

### wifi: config ###
    chmod 0777 /data/vendor/misc/wifi/wpa_supplicant.conf

### bluetooth: bt log ###
    mkdir /data/vendor/@btmtk 0770 bluetooth net_bt

### suspend_to_dram ###
    chown radio system /sys/power/suspend
    chmod 0660 /sys/power/suspend
    chmod 0660 /sys/power/wakeup_count

### surfaceflinger: remove surfaceflinger from system_server ###
# Set this property to 0 so surfaceflinger is not started by system_init
    setprop system_init.startsurfaceflinger 0
### surfaceflinger: end


# This property trigger has added to imitiate the previous behavior of "adb root".
# The adb gadget driver used to reset the USB bus when the adbd daemon exited,
# and the host side adb relied on this behavior to force it to reconnect with the
# new adbd instance after init relaunches it. So now we force the USB bus to reset
# here when adbd sets the service.adb.root property to 1.  We also restart adbd here
# rather than waiting for init to notice its death and restarting it so the timing
# of USB resetting and adb restarting more closely matches the previous behavior.
on property:service.adb.root=1
    write /sys/class/android_usb/android0/enable 0
    restart adbd
    write /sys/class/android_usb/android0/enable 1

### run console
# mtk: temparily move this to let console service run quickly
# on property:ro.mtk.console_support=1
#     start console
