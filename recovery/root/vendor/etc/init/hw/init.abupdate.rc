on post-fs

    # symlink for A/B partitions
    symlink /dev/block/bootdevice/by-name/dtbo${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/dtbo
    symlink /dev/block/bootdevice/by-name/vbmeta${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/vbmeta
    symlink /dev/block/bootdevice/by-name/dvbsDB${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/dvbsDB
    symlink /dev/block/bootdevice/by-name/boot${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/boot
    symlink /dev/block/bootdevice/by-name/system${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/system
    symlink /dev/block/bootdevice/by-name/linux_rootfs${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/linux_rootfs
    symlink /dev/block/bootdevice/by-name/basic${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/basic
    symlink /dev/block/bootdevice/by-name/3rd${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/3rd
    symlink /dev/block/bootdevice/by-name/aq${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/aq
	symlink /dev/block/bootdevice/by-name/aud_dat${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/aud_dat
    symlink /dev/block/bootdevice/by-name/pq${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/pq
	symlink /dev/block/bootdevice/by-name/pq_raw${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/pq_raw
    symlink /dev/block/bootdevice/by-name/logo${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/logo
    symlink /dev/block/bootdevice/by-name/tzbp${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/tzbp
    symlink /dev/block/bootdevice/by-name/adsp${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/adsp
    symlink /dev/block/bootdevice/by-name/vendor${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/vendor
    symlink /dev/block/bootdevice/by-name/odm${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/odm
    symlink /dev/block/bootdevice/by-name/factory${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/factory
    symlink /dev/block/bootdevice/by-name/r20${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/r20
    symlink /dev/block/bootdevice/by-name/r21${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/r21
    symlink /dev/block/bootdevice/by-name/3dlut${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/3dlut
    symlink /dev/block/bootdevice/by-name/cm4${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/cm4
    symlink /dev/block/bootdevice/by-name/Panel_Table${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/Panel_Table
    symlink /dev/block/bootdevice/by-name/tpv_misc${ro.boot.slot_suffix} /dev/block/bootdevice/by-name/tpv_misc
    
    # symlink for none-A/B partitions
    symlink /dev/block/bootdevice/by-name/uboot /dev/block/bootdevice/by-name/uboot_a
    symlink /dev/block/bootdevice/by-name/uboot /dev/block/bootdevice/by-name/uboot_b
    symlink /dev/block/bootdevice/by-name/uboot_env /dev/block/bootdevice/by-name/uboot_env_a
    symlink /dev/block/bootdevice/by-name/uboot_env /dev/block/bootdevice/by-name/uboot_env_b
    symlink /dev/block/bootdevice/by-name/perm /dev/block/bootdevice/by-name/perm_a
    symlink /dev/block/bootdevice/by-name/perm /dev/block/bootdevice/by-name/perm_b
    symlink /dev/block/bootdevice/by-name/ciplus /dev/block/bootdevice/by-name/ciplus_a
    symlink /dev/block/bootdevice/by-name/ciplus /dev/block/bootdevice/by-name/ciplus_b
    symlink /dev/block/bootdevice/by-name/eeprom_A /dev/block/bootdevice/by-name/eeprom_A_a
    symlink /dev/block/bootdevice/by-name/eeprom_A /dev/block/bootdevice/by-name/eeprom_A_b
    symlink /dev/block/bootdevice/by-name/misc /dev/block/bootdevice/by-name/misc_a
    symlink /dev/block/bootdevice/by-name/misc /dev/block/bootdevice/by-name/misc_b
    symlink /dev/block/bootdevice/by-name/oem /dev/block/bootdevice/by-name/oem_a
    symlink /dev/block/bootdevice/by-name/oem /dev/block/bootdevice/by-name/oem_b
    symlink /dev/block/bootdevice/by-name/3rd_rw /dev/block/bootdevice/by-name/3rd_rw_a
    symlink /dev/block/bootdevice/by-name/3rd_rw /dev/block/bootdevice/by-name/3rd_rw_b
    symlink /dev/block/bootdevice/by-name/channelA /dev/block/bootdevice/by-name/channelA_a
    symlink /dev/block/bootdevice/by-name/channelA /dev/block/bootdevice/by-name/channelA_b
    symlink /dev/block/bootdevice/by-name/channelB /dev/block/bootdevice/by-name/channelB_a
    symlink /dev/block/bootdevice/by-name/channelB /dev/block/bootdevice/by-name/channelB_b
    symlink /dev/block/bootdevice/by-name/hdcp /dev/block/bootdevice/by-name/hdcp_a
    symlink /dev/block/bootdevice/by-name/hdcp /dev/block/bootdevice/by-name/hdcp_b
    symlink /dev/block/bootdevice/by-name/edid /dev/block/bootdevice/by-name/edid_a
    symlink /dev/block/bootdevice/by-name/edid /dev/block/bootdevice/by-name/edid_b
    symlink /dev/block/bootdevice/by-name/upgrade /dev/block/bootdevice/by-name/upgrade_a
    symlink /dev/block/bootdevice/by-name/upgrade /dev/block/bootdevice/by-name/upgrade_b
    symlink /dev/block/bootdevice/by-name/dolby /dev/block/bootdevice/by-name/dolby_a
    symlink /dev/block/bootdevice/by-name/dolby /dev/block/bootdevice/by-name/dolby_b
    symlink /dev/block/bootdevice/by-name/SCHEDPVR /dev/block/bootdevice/by-name/SCHEDPVR_a
    symlink /dev/block/bootdevice/by-name/SCHEDPVR /dev/block/bootdevice/by-name/SCHEDPVR_b
    symlink /dev/block/bootdevice/by-name/userdata /dev/block/bootdevice/by-name/userdata_a
    symlink /dev/block/bootdevice/by-name/userdata /dev/block/bootdevice/by-name/userdata_b
    symlink /dev/block/bootdevice/by-name/metadata /dev/block/bootdevice/by-name/metadata_a
    symlink /dev/block/bootdevice/by-name/metadata /dev/block/bootdevice/by-name/metadata_b
	symlink /dev/block/bootdevice/by-name/ubootB /dev/block/bootdevice/by-name/ubootB_a
    symlink /dev/block/bootdevice/by-name/ubootB /dev/block/bootdevice/by-name/ubootB_b
    symlink /dev/block/bootdevice/by-name/uboot_envB /dev/block/bootdevice/by-name/uboot_envB_a
    symlink /dev/block/bootdevice/by-name/uboot_envB /dev/block/bootdevice/by-name/uboot_envB_b
    symlink /dev/block/bootdevice/by-name/bootlogo /dev/block/bootdevice/by-name/bootlogo_a
    symlink /dev/block/bootdevice/by-name/bootlogo /dev/block/bootdevice/by-name/bootlogo_b
