    symlink /dev/block/dm-15 /dev/mapper/dm-15
    symlink /dev/block/dm-16 /dev/mapper/dm-16
    symlink /dev/block/dm-17 /dev/mapper/dm-17
    symlink /dev/block/dm-18 /dev/mapper/dm-18
    symlink /dev/block/dm-19 /dev/mapper/dm-19
    symlink /dev/block/dm-20 /dev/mapper/dm-20
    symlink /dev/block/dm-21 /dev/mapper/dm-21
    symlink /dev/block/dm-22 /dev/mapper/dm-22
    symlink /dev/block/dm-23 /dev/mapper/dm-23
    symlink /dev/block/dm-24 /dev/mapper/dm-24
    symlink /dev/block/dm-25 /dev/mapper/dm-25
    symlink /dev/block/dm-26 /dev/mapper/dm-26
    symlink /dev/block/dm-27 /dev/mapper/dm-27
    symlink /dev/block/dm-28 /dev/mapper/dm-28
    symlink /dev/block/dm-29 /dev/mapper/dm-29
    symlink /dev/block/dm-30 /dev/mapper/dm-30
    symlink /dev/block/dm-31 /dev/mapper/dm-31
    symlink /dev/block/ramzswap0 /dev/ramzswap0
    symlink /dev/block/zram0 /dev/zram0
    symlink /dev/block/zram1 /dev/zram1

    write /mnt/vendor/tmp/perm_mounted 0
    write /mnt/vendor/tmp/3rd_mounted 0
    write /mnt/vendor/tmp/3rd_ro_mounted 0

    # dmverity
    restorecon_recursive /dev/mapper

    restorecon_recursive /dev/block

on post-fs-data
    write /mnt/vendor/tmp/mknod_util_end 0
    restorecon_recursive /mnt/vendor/tmp

    write /proc/boottime "==> mknod_util end"
