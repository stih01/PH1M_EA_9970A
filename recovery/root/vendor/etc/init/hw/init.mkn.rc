on post-fs
    write /proc/boottime "==> mknod_util start"

    # create folder in /dev
    mkdir /dev/fusion
    mkdir /dev/shm
    mkdir /dev/graphics
    restorecon_recursive /dev/fusion
    restorecon_recursive /dev/shm

